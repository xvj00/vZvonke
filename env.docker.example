# Скопируйте в .env в корне проекта:
#   cp env.docker.example .env      (Linux/macOS)
#   copy env.docker.example .env    (Windows)
# Затем заполните все значения, отмеченные как ОБЯЗАТЕЛЬНО.

# ==============================================================================
# ОБЯЗАТЕЛЬНО
# ==============================================================================

# Сгенерировать: docker run --rm php:8.2-cli php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=base64:СГЕНЕРИРУЙТЕ_ЗДЕСЬ

# Публичный URL сайта (без слеша в конце)
APP_URL=https://ваш-домен.ru

# Пароль root MySQL (только для healthcheck внутри контейнера)
DB_ROOT_PASSWORD=надежный_пароль_root_mysql

# Пароль пользователя БД
DB_PASSWORD=надежный_пароль_пользователя_бд

# Имя БД и пользователь (можно оставить как есть)
DB_DATABASE=vzvonke
DB_USERNAME=vzvonke

# Публичный IPv4 вашего VPS (для WebRTC ICE-кандидатов)
# Узнать: curl -s https://api.ipify.org
MEDIASOUP_ANNOUNCED_IP=203.0.113.10

# URL сигналинга mediasoup, доступный из браузера пользователя.
# При network_mode: host mediasoup работает прямо на порту хоста 4001.
VITE_MEDIASOUP_SIGNALING_URL=https://ваш-домен.ru:4001

# ==============================================================================
# ПРОДАКШЕН (рекомендуется не менять)
# ==============================================================================

APP_ENV=production
APP_DEBUG=false

# Порт Nginx на хосте
HTTP_PORT=80

# Порт mediasoup-сигналинга
MEDIASOUP_PORT=4001

# Домены для Sanctum CSRF (через запятую, без https://)
SANCTUM_STATEFUL_DOMAINS=ваш-домен.ru,www.ваш-домен.ru

# Фронт ходит на тот же хост через /api
VITE_API_URL=/api

# Если SPA и API на разных origin — раскомментировать:
# VITE_APP_BASE_URL=https://ваш-домен.ru

# mediasoup обращается к Laravel через Docker-сеть (при host-режиме — через localhost)
LARAVEL_API_URL=http://127.0.0.1/api

# Только авторизованные пользователи могут звонить
REQUIRE_ROOM_AUTH=true
VITE_REQUIRE_AUTH_FOR_CALLS=true

# ==============================================================================
# MEDIASOUP — НАСТРОЙКИ ДЛЯ СЕРВЕРА 2 CPU / 2 GB RAM
# ==============================================================================

# UDP-диапазон для RTP-потоков WebRTC.
# На хостинге ОБЯЗАТЕЛЬНО открыть эти порты в фаерволе для UDP.
# Совет для 2GB-сервера: можно сузить до 40000-40499 (500 портов),
# это покроет ~100 одновременных потоков.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40499
RTC_UDP_RANGE=40000-40499

# Сколько mediasoup-воркеров запускать.
# Каждый воркер — отдельный нативный процесс (~100-150MB RAM).
# На 2GB сервере достаточно 1 воркера (покрывает 10-20 участников).
MEDIASOUP_NUM_WORKERS=1

# Максимум участников в одной комнате.
# Реалистично для 2CPU/2GB: 10-15 видеоучастников.
MAX_PEERS_PER_ROOM=15

# Исходящий битрейт на транспорт (бит/с).
# 600000 = 600 кбит/с — хороший баланс качества и нагрузки.
MEDIASOUP_INITIAL_OUTGOING_BITRATE=600000

# Входящий лимит. Раскомментировать если нужно ограничить загрузку от клиентов:
# MEDIASOUP_MAX_INCOMING_BITRATE=800000

# Секрет для внутреннего API между Laravel и mediasoup.
# ОБЯЗАТЕЛЬНО установить в продакшене — длинная случайная строка.
# Генерировать: openssl rand -hex 32
MEDIASOUP_INTERNAL_SECRET=СГЕНЕРИРУЙТЕ_СЛУЧАЙНУЮ_СТРОКУ

# Через сколько мс после ухода последнего участника удалять комнату из памяти
EMPTY_ROOM_GRACE_MS=30000

# Токен для GET /metrics (опционально, пусто = без авторизации)
# METRICS_TOKEN=
