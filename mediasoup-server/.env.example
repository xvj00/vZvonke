PORT=4001
MEDIASOUP_LISTEN_IP=127.0.0.1
MEDIASOUP_ANNOUNCED_IP=
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
LARAVEL_API_URL=http://127.0.0.1:8000/api
# false только для локальной отладки без токена
REQUIRE_ROOM_AUTH=true

# Секрет для заголовка X-Mediasoup-Secret (тот же ключ в Laravel MEDIASOUP_INTERNAL_SECRET). В проде обязательно.
MEDIASOUP_INTERNAL_SECRET=
# Удаление mediasoup-комнаты из памяти после ухода всех (мс)
EMPTY_ROOM_GRACE_MS=30000

# Макс. участников в одной комнате (сигнальный peer)
MAX_PEERS_PER_ROOM=50

# Сколько процессов mediasoup worker (round-robin на новые комнаты). По умолчанию: min(8, число CPU).
# MEDIASOUP_NUM_WORKERS=4

# Битрейт WebRtcTransport, бит/с: для VP8-видео обычно 500k–2M. 64000 — только если нужен почти аудио-режим.
MEDIASOUP_INITIAL_OUTGOING_BITRATE=1000000

# Ограничить входящий битрейт на транспорт (необязательно; бит/с)
# MEDIASOUP_MAX_INCOMING_BITRATE=1000000

# Если задан — GET /metrics только с заголовком Authorization: Bearer <token>
# METRICS_TOKEN=
