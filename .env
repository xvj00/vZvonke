# Скопируйте в .env в каталоге diplomSam:
#   copy env.docker.example .env   (Windows)
#   cp env.docker.example .env     (Linux/macOS)

# --- Обязательно ---
APP_KEY=base64:СГЕНЕРИРУЙТЕ_ЧЕРЕЗ_php_artisan_key_generate
APP_URL=https://ваш-домен.ru

DB_ROOT_PASSWORD=надежный_пароль_root_mysql
DB_PASSWORD=надежный_пароль_пользователя_бд
DB_DATABASE=vzvonke
DB_USERNAME=vzvonke

# Публичный IPv4 сервера (для WebRTC / ICE в mediasoup)
MEDIASOUP_ANNOUNCED_IP=203.0.113.10

# Что вписать в сборку фронта: полный URL сигналинга, доступный из браузера пользователя
# Пример, если mediasoup наружу на порту 4001:
VITE_MEDIASOUP_SIGNALING_URL=https://ваш-домен.ru:4001
# Если позже спрячете сигналинг за тем же Nginx/HTTPS — поменяйте на этот URL и пересоберите web.

# --- Рекомендуется для продакшена ---
APP_ENV=production
APP_DEBUG=false
HTTP_PORT=80
MEDIASOUP_PORT=4001

# Домены SPA для Sanctum (через запятую, без схемы)
SANCTUM_STATEFUL_DOMAINS=ваш-домен.ru,www.ваш-домен.ru

# Префикс API для Vite (по умолчанию фронт ходит на тот же хост)
VITE_API_URL=/api

# Опционально: если отдаёте SPA с другого origin
# VITE_APP_BASE_URL=https://ваш-домен.ru

# Внутри Docker-сети mediasoup дергает Laravel так (менять не нужно, если не переименовывали сервисы)
LARAVEL_API_URL=http://web/api

REQUIRE_ROOM_AUTH=true

# UDP-порты RTP mediasoup (должны совпадать с правилами фаервола на хосте)
RTC_UDP_RANGE=40000-49999
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

EMPTY_ROOM_GRACE_MS=30000
